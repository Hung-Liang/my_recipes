{
  "name": "高蛋白雞胸肉披薩餃",
  "description": "這是一款無麩質、低碳水的創意披薩餃。使用攪碎的雞胸肉作為餅皮底材，內餡包裹著濃郁起司、火腿與鮮甜番茄，提供極高的蛋白質含量，非常適合健身族群。",
  "servings": {
    "quantity": 1,
    "unit": "份"
  },
  "tags": [
    "高蛋白",
    "低碳水",
    "生酮友善",
    "健身料理",
    "雞胸肉料理"
  ],
  "ingredients": [
    {
      "name": "雞胸肉",
      "quantity": 450,
      "unit": "g"
    },
    {
      "name": "奶油乳酪",
      "quantity": 40,
      "unit": "g"
    },
    {
      "name": "起司片",
      "quantity": 40,
      "unit": "g"
    },
    {
      "name": "火腿",
      "quantity": 60,
      "unit": "g"
    },
    {
      "name": "中型番茄",
      "quantity": 150,
      "unit": "g"
    },
    {
      "name": "帕瑪森起司",
      "quantity": 10,
      "unit": "g"
    },
    {
      "name": "鹽",
      "quantity": 3,
      "unit": "g"
    },
    {
      "name": "胡椒",
      "quantity": 1,
      "unit": "g"
    }
  ],
  "steps": [
    "將雞胸肉切塊後放入攪拌機，攪打成細緻的肉泥。",
    "在烘焙紙上鋪開雞胸肉泥，並將其壓平、抹勻，整形成圓形的「餅皮」。",
    "在肉泥餅皮的一側依序鋪上奶油乳酪、切片番茄、火腿與起司片。",
    "將餅皮對摺成半月形的披薩餃狀，封住邊緣。",
    "在表面撒上帕瑪森起司粉，並視需求撒上鹽與胡椒調味。",
    "放入預熱至 200°C 的烤箱中烘烤 25 分鐘，直到表面呈現誘人的金黃色即可。"
  ],
  "notes": [
    "雞胸肉：2 塊約為 450 g。",
    "火腿：3 片約為 60 g。",
    "中型番茄：1 顆約為 150 g。",
    "鹽與胡椒：原食譜未標註具體份量，已根據食材比例估算為 3 g 鹽與 1 g 胡椒。",
    "製作建議：雞肉泥盡量鋪得厚薄均勻，確保烘烤時受熱一致。"
  ]
}