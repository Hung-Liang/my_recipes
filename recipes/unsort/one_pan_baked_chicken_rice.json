{
  "name": "烤箱雞胸米飯",
  "description": "這是一道簡單且營養均衡的高蛋白懶人餐。將雞胸肉、米飯與雞高湯一同烘烤，米飯能吸飽肉汁與高湯精華，口感鮮美且雞肉鮮嫩多汁，非常適合增肌減脂族群。",
  "servings": {
    "quantity": 4,
    "unit": "份"
  },
  "tags": [
    "高蛋白",
    "低GI",
    "健身料理",
    "一鍋到底",
    "烤箱料理"
  ],
  "ingredients": [
    {
      "name": "米",
      "quantity": 200,
      "unit": "g"
    },
    {
      "name": "雞胸肉",
      "quantity": 600,
      "unit": "g"
    },
    {
      "name": "帕瑪森起司",
      "quantity": 50,
      "unit": "g"
    },
    {
      "name": "青醬",
      "quantity": 50,
      "unit": "g"
    },
    {
      "name": "花椰菜",
      "quantity": 200,
      "unit": "g"
    },
    {
      "name": "小番茄",
      "quantity": 300,
      "unit": "g"
    },
    {
      "name": "雞高湯",
      "quantity": 400,
      "unit": "ml"
    },
    {
      "name": "鹽",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "胡椒",
      "quantity": 2,
      "unit": "g"
    }
  ],
  "steps": [
    "將烤箱預熱至 190°C。",
    "準備一個烤盤，倒入米與雞高湯。",
    "將雞胸肉鋪在米飯上方，並均勻撒上鹽與胡椒調味。",
    "在雞肉周圍放入花椰菜與小番茄。",
    "均勻拌入青醬與帕瑪森起司。",
    "放入預熱好的烤箱烘烤 40 至 45 分鐘，確認雞肉熟透且米飯吸乾水分後即可出爐。"
  ],
  "notes": [
    "鹽與胡椒：原食譜未標註份量，已根據 4 人份標準料理比例估算為 5g 鹽與 2g 胡椒。",
    "食材重量參考：若使用中型小番茄，300g 約為 20-25 顆。",
    "米飯口感：若喜歡較軟的米飯，可額外多加 30-50ml 的雞高湯。",
    "健康提醒：此料理富含纖維與蛋白質，是理想的增肌減脂餐。"
  ]
}