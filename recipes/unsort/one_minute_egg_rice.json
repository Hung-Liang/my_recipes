{
  "name": "雞蛋撈飯",
  "description": "只需一分鐘即可完成的省錢美味料理，非常適合忙碌或想節省預算的懶人食譜。",
  "servings": {
    "quantity": 1,
    "unit": "份"
  },
  "tags": [
    "簡單料理",
    "省錢",
    "微波爐料理",
    "懶人食譜",
    "雞蛋料理"
  ],
  "ingredients": [
    {
      "name": "白飯",
      "quantity": 200,
      "unit": "g"
    },
    {
      "name": "雞蛋",
      "quantity": 50,
      "unit": "g"
    },
    {
      "name": "醬油",
      "quantity": 15,
      "unit": "ml"
    },
    {
      "name": "麻油",
      "quantity": 7.5,
      "unit": "ml"
    },
    {
      "name": "水",
      "quantity": 30,
      "unit": "ml"
    }
  ],
  "steps": [
    "在容器中加入一湯匙醬油、半湯匙麻油及兩勺水，攪拌均勻。",
    "打入一顆雞蛋，並務必使用筷子或叉子將蛋黃戳破（防止微波時爆炸）。",
    "將容器放入微波爐中，以高火加熱 1 分鐘。",
    "取出後將其淋在白飯上，攪拌均勻即可享用。"
  ],
  "notes": [
    "雞蛋：1 顆約為 50 g。",
    "白飯：1 份標準碗約為 200 g。",
    "醬油：1 湯匙換算約為 15 ml。",
    "麻油：半湯匙換算約為 7.5 ml。",
    "水：2 勺（以標準平匙計）換算約為 30 ml。",
    "安全提醒：微波雞蛋前請務必戳破蛋黃與蛋白，以免發生爆裂危險。"
  ]
}