{
    "name": "電鍋腐乳梅花肉",
    "description": "只需簡單醃製並使用電鍋即可輕鬆完成的美味豬肉料理，醬香濃郁且肉質軟嫩。",
    "servings": {
        "quantity": 1,
        "unit": "份"
    },
    "tags": [
        "中式",
        "家常菜",
        "簡單",
        "豬肉",
        "電鍋"
    ],
    "ingredients": [
        {
            "name": "豆腐乳",
            "quantity": 1,
            "unit": "塊"
        },
        {
            "name": "蜂蜜",
            "quantity": 1,
            "unit": "杓"
        },
        {
            "name": "蠔油",
            "quantity": 1,
            "unit": "杓"
        },
        {
            "name": "梅花肉",
            "quantity": 1,
            "unit": "塊"
        },
        {
            "name": "醬油",
            "quantity": 1,
            "unit": "大杓"
        },
        {
            "name": "蔥",
            "quantity": 0,
            "unit": "適量"
        },
        {
            "name": "薑",
            "quantity": 0,
            "unit": "適量"
        },
        {
            "name": "鹽巴",
            "quantity": 0,
            "unit": "適量"
        },
        {
            "name": "胡椒粉",
            "quantity": 0,
            "unit": "適量"
        }
    ],
    "steps": [
        "將一塊豆腐乳、一杓蜂蜜、一杓蠔油混合並攪拌均勻，作為醬汁備用。",
        "準備塊狀的梅花肉，加入蔥段、薑片、鹽巴、胡椒粉、一大杓醬油。",
        "倒入剛剛調好的醬汁，用手將肉與醬料充分抓拌均勻。",
        "將抓勻的梅花肉放入冰箱冷藏醃製兩小時使其入味。",
        "在電鍋內鍋底部鋪上薑片與蔥段。",
        "將醃好的梅花肉放進內鍋，並將剩餘的醃肉醬汁一併倒入。",
        "按下電鍋的煮飯按鈕，等待煮熟跳起即可。"
    ],
    "notes": [
        "梅花肉務必購買「塊狀」而非肉片，這樣燉煮出來的口感才會好且保有肉汁。",
        "電鍋跳起後建議悶 10 到 15 分鐘再開蓋，風味會更佳。"
    ]
}