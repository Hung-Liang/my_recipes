{
  "name": "牛丼飯",
  "description": "經典的日式家常定食，利用洋蔥與日式基礎調味醬汁燉煮牛肉片，製作過程簡單快速，鹹甜滋味與白飯完美結合。",
  "servings": {
    "quantity": 1,
    "unit": "份"
  },
  "tags": [
    "日式",
    "牛肉",
    "澱粉",
    "懶人料理"
  ],
  "ingredients": [
    {
      "name": "牛肉片",
      "quantity": 250,
      "unit": "g"
    },
    {
      "name": "洋蔥",
      "quantity": 240,
      "unit": "g"
    },
    {
      "name": "白飯",
      "quantity": 200,
      "unit": "g"
    },
    {
      "name": "水",
      "quantity": 200,
      "unit": "ml"
    },
    {
      "name": "醬油",
      "quantity": 45,
      "unit": "ml"
    },
    {
      "name": "白砂糖",
      "quantity": 30,
      "unit": "g"
    },
    {
      "name": "米酒",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "味醂",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "薑末",
      "quantity": 5,
      "unit": "g"
    }
  ],
  "steps": [
    "準備醬汁：將水、醬油、糖、米酒、味醂與薑末在鍋中混合均勻。",
    "燉煮洋蔥：洋蔥切成絲，放入鍋中與調好的醬汁一同煮滾，維持中小火燉煮約 5 分鐘至洋蔥軟化。",
    "煮牛肉：接著放入牛肉片，以中小火繼續煮約 5 分鐘，確保牛肉片完全熟透並吸附醬汁。",
    "盛盤：在碗中盛入熱騰騰的白飯，淋上煮好的牛肉、洋蔥與適量醬汁即可享用。"
  ],
  "notes": [
    "洋蔥：1 顆約為 240 g。",
    "薑末：適量約估計為 5 g。",
    "白飯：1 份約為 200 g。",
    "調味比例：1 大匙約為 15 ml 或 15 g。"
  ]
}