{
  "filename": "creamy_tofu_shell_pasta.json",
  "name": "奶油豆腐白醬貝殼麵",
  "description": "這是一款利用板豆腐與燕麥奶調製而成的蔬食白醬義大利麵，口感濃郁且清爽健康。",
  "servings": {
    "quantity": 2,
    "unit": "份"
  },
  "tags": [
    "蔬食",
    "義大利麵",
    "板豆腐",
    "白醬"
  ],
  "ingredients": [
    {
      "name": "貝殼義大利麵",
      "quantity": 160,
      "unit": "g"
    },
    {
      "name": "油漬番茄",
      "quantity": 50,
      "unit": "g"
    },
    {
      "name": "板豆腐",
      "quantity": 300,
      "unit": "g"
    },
    {
      "name": "燕麥奶",
      "quantity": 200,
      "unit": "ml"
    },
    {
      "name": "鹽巴（豆腐醬用）",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "黑胡椒粉",
      "quantity": 4,
      "unit": "g"
    },
    {
      "name": "鹽巴（調味用）",
      "quantity": 10,
      "unit": "g"
    },
    {
      "name": "水",
      "quantity": 700,
      "unit": "ml"
    },
    {
      "name": "辣椒油",
      "quantity": 3,
      "unit": "ml"
    }
  ],
  "steps": [
    "將板豆腐、燕麥奶及 1 小匙鹽巴放入調理機中打成泥狀備用。",
    "起鍋熱油，放入黑胡椒粉與番茄乾翻炒。",
    "待聞到香氣後，倒入 700ml 的水。",
    "加入義大利麵與 2 小匙鹽巴燉煮。",
    "待義大利麵煮至約 8 分熟時，倒入準備好的豆腐醬，煮至湯汁收乾呈現濃稠狀即可。"
  ],
  "notes": [
    "貝殼義大利麵：2人份約為 160 g。",
    "油漬番茄：5～6 顆約為 50 g。",
    "板豆腐：1 塊約為 300 g。",
    "鹽巴：1 小匙約為 5 g。",
    "黑胡椒粉：2 小匙約為 4 g。",
    "辣椒油：少許（適量）預估為 3 ml。",
    "義大利麵種類可以依個人喜好挑選替換。"
  ]
}