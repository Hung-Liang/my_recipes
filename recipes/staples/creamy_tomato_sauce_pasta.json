      "unit": "g"
    },
    {
      "name": "鮮奶油 (12%)",
      "quantity": 200,
      "unit": "ml"
    },
    {
      "name": "番茄糊",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "熟義大利麵",
