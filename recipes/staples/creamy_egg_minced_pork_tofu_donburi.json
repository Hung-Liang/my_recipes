{
  "name": "滑蛋肉末豆腐蓋飯",
  "description": "味道超下飯的快手料理！蒜頭與絞肉炒香後，搭配豆腐與雞蛋兩種滑嫩食材，口感豐富且非常下飯。",
  "servings": {
    "quantity": 2,
    "unit": "份"
  },
  "tags": [
    "主食",
    "懶人料理",
    "日式",
    "澱粉",
    "豆腐",
    "豬肉"
  ],
  "ingredients": [
    {
      "name": "絞肉",
      "quantity": 180,
      "unit": "g"
    },
    {
      "name": "嫩豆腐",
      "quantity": 300,
      "unit": "g"
    },
    {
      "name": "雞蛋",
      "quantity": 150,
      "unit": "g"
    },
    {
      "name": "玉米粉水",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "醬油",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "味醂",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "米酒",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "水",
      "quantity": 100,
      "unit": "ml"
    },
    {
      "name": "高湯粉",
      "quantity": 7.5,
      "unit": "g"
    },
    {
      "name": "蒜頭",
      "quantity": 15,
      "unit": "g"
    },
    {
      "name": "蔥",
      "quantity": 10,
      "unit": "g"
    },
    {
      "name": "食用油",
      "quantity": 15,
      "unit": "ml"
    }
  ],
  "steps": [
    "將蔥切成蔥花、蒜頭切成末、雞蛋打散備用。",
    "將醬油、味醂、米酒、水與高湯粉預先混合均勻作為調味料備用。",
    "鍋中倒入食用油，加入絞肉並以大火炒熟炒散。",
    "加入蒜末繼續炒香，接著加入嫩豆腐並用湯匙切成小塊。",
    "倒入混合好的調味料煮滾，轉中火煮約 3-4 分鐘至豆腐入味。",
    "加入玉米粉水進行勾芡，接著倒入蛋液並輕輕推動至 7 分熟狀態。",
    "最後撒上蔥花即可完成。"
  ],
  "notes": [
    "嫩豆腐：1塊約為 300 g",
    "雞蛋：3顆（1顆約為 50 g）",
    "大匙換算：1大匙約為 15 ml；1/2大匙約為 7.5 ml/g",
    "蒜頭與蔥：根據料理份量預估重量",
    "推蛋小撇步：在推蛋液的時候，注意不要把已經熟的蛋翻上來，以保持滑嫩口感。",
    "勾芡建議：適度的勾芡可以讓蛋液呈現更好的滑蛋狀態。",
    "粉水比例：玉米粉與水的比例建議為 1:2。"
  ]
}
