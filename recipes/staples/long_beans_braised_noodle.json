{
  "name": "四季豆悶麵",
  "description": "好吃又簡單的乾麵",
  "servings": {
    "quantity": 2,
    "unit": "份"
  },
  "tags": [
    "澱粉",
    "懶人料理"
  ],
  "ingredients": [
    {
      "name": "生拉麵 (中式拉麵)",
      "quantity": 300,
      "unit": "g"
    },
    {
      "name": "五花肉 (梅花肉亦可)",
      "quantity": 300,
      "unit": "g"
    },
    {
      "name": "醬油",
      "quantity": 15,
      "unit": "ml"
    },
    {
      "name": "味精",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "糖",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "米酒",
      "quantity": 15,
      "unit": "ml"
    },
    {
      "name": "水",
      "quantity": 300,
      "unit": "ml"
    },
    {
      "name": "四季豆",
      "quantity": 300,
      "unit": "g"
    },
    {
      "name": "蒜頭",
      "quantity": 25,
      "unit": "g"
    }
  ],
  "steps": [
    "五花肉切片，蒜頭切末，四季豆切段備用。",
    "醬油、味精、糖、水調成醬汁備用。",
    "熱鍋後放入五花肉片煸炒至出油且微焦，加入蒜末爆香。",
    "鍋邊加入米酒去腥。",
    "加入四季豆以及調好的醬汁，蓋上鍋蓋悶煮約 10 分鐘至四季豆熟透。",
    "撈出 1/3 鍋中的湯汁備用。",
    "將拉麵均勻的鋪在鍋中料的上面，蓋上鍋蓋悶煮約 5 分鐘。",
    "打開鍋蓋，將撈出的湯汁淋在拉麵上，再悶煮 3 分鐘。",
    "將麵條拌勻醬汁收乾即可盛盤。"
  ],
  "notes": [
    "如果使用梅花肉請加油。",
    "喜歡吃辣的可以加些辣椒一起悶煮。",
    "醬油、米酒：1 大匙換算為 15 ml。",
    "味精、糖：1 小匙換算為 5 g。",
    "蒜頭：5 瓣約為 25 g。"
  ]
}
