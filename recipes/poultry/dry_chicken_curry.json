{
  "name": "高蛋白雞胸肉乾咖哩",
  "description": "這是一道高蛋白質且低熱量的健康料理，利用雞胸肉與大量蔬菜炒香收乾，風味濃郁。相較於日式咖哩塊，使用咖哩粉製作可減少油脂與澱粉攝取，非常適合飲控與忙碌上班族批次製作冷凍備餐。",
  "servings": {
    "quantity": 2,
    "unit": "份"
  },
  "tags": [
    "高蛋白",
    "雞肉",
    "懶人料理"
  ],
  "ingredients": [
    {
      "name": "雞胸肉",
      "quantity": 350,
      "unit": "g"
    },
    {
      "name": "洋蔥",
      "quantity": 200,
      "unit": "g"
    },
    {
      "name": "蒜頭",
      "quantity": 15,
      "unit": "g"
    },
    {
      "name": "薑",
      "quantity": 10,
      "unit": "g"
    },
    {
      "name": "番茄罐頭",
      "quantity": 400,
      "unit": "g"
    },
    {
      "name": "伍斯特醬",
      "quantity": 15,
      "unit": "ml"
    },
    {
      "name": "味噌",
      "quantity": 15,
      "unit": "g"
    },
    {
      "name": "番茄醬",
      "quantity": 15,
      "unit": "g"
    },
    {
      "name": "咖哩粉",
      "quantity": 6,
      "unit": "g"
    },
    {
      "name": "鹽",
      "quantity": 3,
      "unit": "g"
    },
    {
      "name": "胡椒",
      "quantity": 1,
