{
  "name": "高蛋白韓式烤雞與甜糯米飯",
  "description": "一道高蛋白的韓式烤雞搭配甜糯米飯的食譜。烤雞使用韓式辣醬、蜂蜜和多種香料醃製，糯米飯則加入米醋和代糖調味。",
  "servings": {
    "quantity": 1,
    "unit": "份"
  },
  "tags": [
    "澱粉/主食",
    "雞肉",
    "韓式",
    "高蛋白"
  ],
  "ingredients": [
    {
      "name": "無骨去皮雞腿肉",
      "quantity": 1000,
      "unit": "g"
    },
    {
      "name": "韓式辣醬（Gochujang）",
      "quantity": 60,
      "unit": "g"
    },
    {
      "name": "蜂蜜",
      "quantity": 30,
      "unit": "g"
    },
    {
      "name": "蒜粉",
      "quantity": 2,
      "unit": "tsp"
    },
    {
      "name": "洋蔥粉",
      "quantity": 1,
      "unit": "tsp"
    },
    {
      "name": "煙燻紅椒粉",
      "quantity": 1,
      "unit": "tsp"
    },
    {
      "name": "白胡椒",
      "quantity": 1,
      "unit": "tsp"
    },
    {
      "name": "薑粉",
      "quantity": 1,
      "unit": "tsp"
    },
    {
      "name": "鹽",
      "quantity": 2,
      "unit": "tsp"
    },
    {
      "name": "噴油",
      "quantity": 5,
      "unit": "ml"
    },
    {
      "name": "生糯米或壽司米（洗淨）",
      "quantity": 250,
      "unit": "g"
    },
    {
      "name": "米醋",
      "quantity": 20,
      "unit": "ml"
    },
    {
      "name": "零卡代糖或砂糖",
      "quantity": 15,
      "unit": "g"
    },
    {
      "name": "鹽（糯米飯用）",
      "quantity": 0.5,
      "unit": "tsp"
    }
  ],
  "steps": [
    "將雞腿肉與韓式辣醬、蜂蜜、蒜粉、洋蔥粉、煙燻紅椒粉、白胡椒、薑粉、鹽混合均勻，靜置醃製。",
    "烤箱預熱至 200°C，將雞腿肉放入烤盤並噴上少許噴油。",
    "烘烤 20-25 分鐘，過半時間翻面一次。",
    "糯米依包裝說明煮熟，悶 10 分鐘後加入米醋、代糖與鹽拌勻。",
    "將烤好的雞腿肉與甜糯米飯裝盤，可搭配蒸青江菜、淋照燒醬，撒上黑芝麻與蔥花裝飾。",
    "享用或分裝作為高蛋白餐前準備。"
  ],
  "notes": [
    "可選配料：蒸青江菜、照燒醬、黑芝麻、蔥花。",
    "糯米飯的鹽用量可依個人口味調整至 1 tsp。",
    "冷藏可保存 5 天。",
    "加熱建議：去掉蓋子，覆蓋濕紙巾，微波 3-4 分鐘以保持肉質水分。"
  ]
}