{
  "name": "蜂蜜蒜香雞肉飯碗",
  "description": "這是一款豐富多層次的飯碗料理，包含烤至金黃酥脆的蜂蜜蒜香雞肉、用多種香料調味的巴斯馬蒂米飯，以及清爽開胃的醃漬紅洋蔥。",
  "servings": {
    "quantity": 5,
    "unit": "份"
  },
  "tags": [
    "中東",
    "澱粉",
    "醬汁",
    "雞肉"
  ],
  "ingredients": [
    {
      "name": "無骨雞腿肉，切丁",
      "quantity": 1100,
      "unit": "g"
    },
    {
      "name": "鹽",
      "quantity": 12,
      "unit": "g"
    },
    {
      "name": "黑胡椒",
      "quantity": 4,
      "unit": "g"
    },
    {
      "name": "煙燻紅椒粉",
      "quantity": 4,
      "unit": "g"
    },
    {
      "name": "蒜粉",
      "quantity": 6,
      "unit": "g"
    },
    {
      "name": "洋蔥粉",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "肉桂粉",
      "quantity": 2,
      "unit": "g"
    },
    {
      "name": "芫荽粉",
      "quantity": 3,
      "unit": "g"
    },
    {
      "name": "橄欖油",
      "quantity": 15,
      "unit": "ml"
    },
    {
      "name": "優格（原味或希臘優格）",
      "quantity": 80,
      "unit": "g"
    },
    {
      "name": "蜂蜜",
      "quantity": 30,
      "unit": "g"
    },
    {
      "name": "紅洋蔥，切薄片",
      "quantity": 200,
      "unit": "g"
    },
    {
      "name": "新鮮巴西里，切碎",
      "quantity": 30,
      "unit": "g"
    },
    {
      "name": "漆樹粉（中東香料）",
      "quantity": 12,
      "unit": "g"
    },
    {
      "name": "檸檬汁",
      "quantity": 40,
      "unit": "ml"
    },
    {
      "name": "生巴斯馬蒂米（需提前煮熟）",
      "quantity": 250,
      "unit": "g"
    },
    {
      "name": "輕奶油奶油",
      "quantity": 20,
      "unit": "g"
    },
    {
      "name": "薑黃粉",
      "quantity": 2,
      "unit": "g"
    },
    {
      "name": "紅椒粉",
      "quantity": 1,
      "unit": "g"
    }
  ],
  "steps": [
    "將雞腿肉與鹽、黑胡椒、煙燻紅椒粉、蒜粉、洋蔥粉、肉桂粉、芫荽粉、橄欖油、優格及蜂蜜拌勻，烤箱或氣炸鍋以 180-190°C 烤 25-28 分鐘至金黃酥脆多汁。",
    "將紅洋蔥、新鮮巴西里碎、漆樹粉、少許鹽與檸檬汁混合，放入密封容器中保存以保持清脆。",
    "低火融化奶油，加入肉桂棒（或肉桂粉）炒 2 分鐘至香氣釋放，加入煮熟的巴斯馬蒂米、薑黃粉、鹽、紅椒粉及部分巴西里碎，溫火輕輕翻拌至米飯鬆軟呈金黃色。",
    "取脆皮雞肉、香料飯與醃漬洋蔥裝碗，可加 2 湯匙原味優格享用。"
  ],
  "notes": [
    "醃漬洋蔥需放入密封容器中保存，方便其他食材重熱時仍能保持新鮮。",
    "可根據個人喜好額外加入約 30g 原味優格享用。",
    "鹽：2 tsp 約換算為 12 g (含醃肉與炒飯總量)。",
    "黑胡椒、煙燻紅椒粉、芫荽粉：1.5-2 tsp 約換算為 3-4 g。",
    "漆樹粉：1.5 tbsp 約換算為 12 g。",
    "檸檬：1 顆榨汁約換算為 40 ml。",
    "新鮮巴西里：一大把約換算為 30 g。",
    "薑黃粉：0.75 tsp 約換算為 2 g。",
    "洋蔥：1 顆約為 200 g。"
  ]
}
