{
  "name": "馬鈴薯牛絞肉漢堡排",
  "description": "將馬鈴薯絲與牛絞肉結合，口感層次豐富且扎實的漢堡排，搭配自製黑胡椒醬汁。",
  "servings": {
    "quantity": 1,
    "unit": "份"
  },
  "tags": [
    "漢堡排",
    "牛絞肉",
    "馬鈴薯",
    "家常菜"
  ],
  "ingredients": [
    {
      "name": "馬鈴薯",
      "quantity": 1,
      "unit": "份"
    },
    {
      "name": "鹽巴",
      "quantity": 0,
      "unit": "適量"
    },
    {
      "name": "牛絞肉",
      "quantity": 1,
      "unit": "份"
    },
    {
      "name": "雞蛋",
      "quantity": 1,
      "unit": "顆"
    },
    {
      "name": "澱粉",
      "quantity": 1,
      "unit": "大杓"
    },
    {
      "name": "黑胡椒",
      "quantity": 0,
      "unit": "適量"
    },
    {
      "name": "熱水",
      "quantity": 0,
      "unit": "適量"
    },
    {
      "name": "醬油",
      "quantity": 1,
      "unit": "杓"
    },
    {
      "name": "蠔油",
      "quantity": 1,
      "unit": "杓"
    },
    {
      "name": "澱粉水",
      "quantity": 1,
      "unit": "杓"
    },
    {
      "name": "冰糖",
      "quantity": 0,
      "unit": "適量"
    }
  ],
  "steps": [
    "將馬鈴薯刨成長絲，加入鹽巴抓醃殺出水分後擠乾。",
    "將擠乾的馬鈴薯絲與牛絞肉以 1:1 的比例均勻混合。",
    "在肉餡中加入一顆雞蛋及一大杓澱粉，攪拌均勻並捏成漢堡排形狀。",
    "撒上黑胡椒，使用中小火將漢堡排正反兩面煎至金黃熟透後盛起。",
    "製作醬汁：鍋內將黑胡椒炒香，加入適量熱水。",
    "加入醬油、蠔油、冰糖調味，最後倒入澱粉水勾芡，待醬汁收濃即可。"
  ],
  "notes": [
    "馬鈴薯絲擠乾水分是漢堡排不散開的關鍵。",
    "醬汁鹹甜度可根據個人口味調整冰糖與醬油的比例。"
  ]
}