{
    "name": "帕瑪森洋蔥脆餅",
    "description": "將帕瑪森起司與洋蔥切片烘烤至金黃酥脆的簡單小點心。",
    "servings": {
        "quantity": 1,
        "unit": "份"
    },
    "tags": [
        "烤箱",
        "點心/小吃"
    ],
    "ingredients": [
        {
            "name": "帕瑪森起司",
            "quantity": 0,
            "unit": "適量"
        },
        {
            "name": "洋蔥",
            "quantity": 0,
            "unit": "切片"
        }
    ],
    "steps": [
        "在烤盤上鋪好烘焙紙。",
        "將帕瑪森起司均勻鋪平在烘焙紙上。",
        "在起司上方放上洋蔥切片。",
        "放入烤箱烘烤，直到起司呈現金黃酥脆狀即可。"
    ],
    "notes": [
        "烘烤時務必使用烘焙紙，以防止起司黏在烤盤上。"
    ]
}