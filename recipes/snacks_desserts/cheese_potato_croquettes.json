{
  "filename": "cheese_potato_croquettes.json",
  "name": "起司馬鈴薯可樂餅",
  "description": "這是一款外皮酥脆、內餡綿密且帶有拉絲起司驚喜的馬鈴薯可樂餅，混合了多種辛香料提升風味，是絕佳的點心選擇。",
  "servings": {
    "quantity": 1,
    "unit": "份"
  },
  "tags": [
    "點心",
    "開胃菜",
    "炸物",
    "起司",
    "馬鈴薯"
  ],
  "ingredients": [
    {
      "name": "馬鈴薯（大顆，煮熟並搗碎）",
      "quantity": 750,
      "unit": "g"
    },
    {
      "name": "紅椒粉",
      "quantity": 2.5,
      "unit": "g"
    },
    {
      "name": "大蒜粉",
      "quantity": 4.5,
      "unit": "g"
    },
    {
      "name": "洋蔥粉",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "黑胡椒",
      "quantity": 2.5,
      "unit": "g"
    },
    {
      "name": "鹽",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "乾燥巴西里（內餡用）",
      "quantity": 1,
      "unit": "g"
    },
    {
      "name": "玉米澱粉",
      "quantity": 25,
      "unit": "g"
    },
    {
      "name": "莫札瑞拉起司塊",
      "quantity": 150,
      "unit": "g"
    },
    {
      "name": "中筋麵粉（Maida）",
      "quantity": 45,
      "unit": "g"
    },
    {
      "name": "水（粉漿用）",
      "quantity": 80,
      "unit": "ml"
    },
    {
      "name": "麵包粉（Panko）",
      "quantity": 60,
      "unit": "g"
    },
    {
      "name": "乾燥巴西里（裹粉用）",
      "quantity": 1,
      "unit": "g"
    },
    {
      "name": "油（油炸用）",
      "quantity": 500,
      "unit": "ml"
    }
  ],
  "steps": [
    "在碗中混合馬鈴薯泥、紅椒粉、大蒜粉、洋蔥粉、黑胡椒、鹽、乾燥巴西里和玉米澱粉，攪拌均勻至質地滑順且易於塑形。",
    "取一份混合好的馬鈴薯泥，在手掌中壓平，於中心放入一顆莫札瑞拉起司塊。",
    "緊緊封口並塑造成橢圓形或圓柱形，確保表面沒有裂縫。",
    "將中筋麵粉和水混合，調製成滑順的麵糊（漿）。",
    "在另一個碗中混合麵包粉和乾燥巴西里。",
    "將每個可樂餅先浸入麵糊中，再均勻裹上麵包粉混合物，輕輕按壓使粉屑附著牢固。",
    "油炸 2–3 分鐘直至表面呈現金黃色。注意不要一次放入過多可樂餅，以免影響鍋溫。",
    "撈起後靜置 1 分鐘。",
    "趁熱搭配您喜愛的沾醬享用。"
  ],
  "notes": [
    "馬鈴薯：1 顆大顆約為 250 g，本食譜使用 3 顆。",
    "莫札瑞拉起司塊：1 塊約為 15 g，本食譜預計製作 10 份。",
    "粉漿用水：份量依麵糊濃稠度調整，建議約 80 ml。",
    "油炸用油：份量以能淹沒可樂餅為準，實際消耗量會依油炸過程而異。",
    "可以根據個人口味調整鹽與黑胡椒的比例。"
  ]
}