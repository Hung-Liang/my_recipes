{
  "name": "椒鹽薯條",
  "description": "這是一道結合中式熱炒風味與西式薯條的創意料理。利用高溫油炸出酥脆的薯條，再與洋蔥、生辣椒及辛香料快速爆炒，香辣鹹香，是極佳的開胃菜或點心。",
  "servings": {
    "quantity": 1,
    "unit": "份"
  },
  "tags": [
    "澱粉",
    "點心",
    "懶人料理"
  ],
  "ingredients": [
    {
      "name": "植物油 (炸用)",
      "quantity": 500,
      "unit": "ml"
    },
    {
      "name": "薯條",
      "quantity": 250,
      "unit": "g"
    },
    {
      "name": "植物油 (炒用)",
      "quantity": 15,
      "unit": "ml"
    },
    {
      "name": "洋蔥",
      "quantity": 100,
      "unit": "g"
    },
    {
      "name": "大蒜粉",
      "quantity": 3,
      "unit": "g"
    },
    {
      "name": "辣椒粉",
      "quantity": 2,
      "unit": "g"
    },
    {
      "name": "生辣椒",
      "quantity": 15,
      "unit": "g"
    },
    {
      "name": "青蔥",
      "quantity": 20,
      "unit": "g"
    },
    {
      "name": "鹽",
      "quantity": 2,
      "unit": "g"
    },
    {
      "name": "味精",
      "quantity": 1,
      "unit": "g"
    }
  ],
  "steps": [
    "將炸油加熱至 190°C。",
    "放入薯條炸至表面金黃酥脆。",
    "撈起薯條，充分瀝乾油脂備用。",
    "另取一炒鍋，加入 15 ml 的油，加熱至微冒煙狀。",
    "放入洋蔥絲快速翻炒。",
    "加入大蒜粉、辣椒粉、生辣椒片與蔥花，翻炒約 30 秒直至香味溢出。",
    "將炸好的薯條倒入鍋中，與辛香料拌合。",
    "加入鹽與味精調味。",
    "快速大火翻炒，確保所有食材充分混合，且薯條均勻沾裹調味料並維持熱度。",
    "立即盛盤上桌享用。"
  ],
  "notes": [
    "薯條：1 份估計約為 250 g。",
    "洋蔥：1/2 顆中型洋蔥估計約為 100 g。",
    "生辣椒：1-2 根估計約為 15 g。",
    "青蔥：1-2 根估計約為 20 g。",
    "油量：炸油量依標準炸鍋深度估算為 500 ml；1 湯匙炒油約為 15 ml。",
    "調味料估算：原食譜中「適量」之鹽、味精、大蒜粉與辣椒粉，分別依比例估算為 2 g、1 g、3 g 與 2 g 以達到理想風味。"
  ]
}