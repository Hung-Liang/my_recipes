{
  "name": "韓式辣炒豬肉",
  "description": "韓國經典的家常靈魂美食，以豬前腿肉搭配韓式辣醬與辣椒粉醃製而成。甜辣適中的風味非常下飯，建議一次醃製大量，分批取出烹炒既方便又入味。",
  "servings": {
    "quantity": 1,
    "unit": "份"
  },
  "tags": [
    "韓式",
    "豬肉",
    "懶人料理"
  ],
  "ingredients": [
    {
      "name": "豬前腿肉",
      "quantity": 600,
      "unit": "g"
    },
    {
      "name": "大蔥",
      "quantity": 100,
      "unit": "g"
    },
    {
      "name": "洋蔥",
      "quantity": 200,
      "unit": "g"
    },
    {
      "name": "青陽辣椒",
      "quantity": 20,
      "unit": "g"
    },
    {
      "name": "辣椒粉",
      "quantity": 30,
      "unit": "g"
    },
    {
      "name": "胡椒粉",
      "quantity": 1,
      "unit": "g"
    },
    {
      "name": "蒜末",
      "quantity": 30,
      "unit": "g"
    },
    {
      "name": "韓式辣醬",
      "quantity": 15,
      "unit": "g"
    },
    {
      "name": "醬油",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "砂糖",
      "quantity": 30,
      "unit": "g"
    },
    {
      "name": "香油",
      "quantity": 15,
      "unit": "ml"
    },
    {
      "name": "白芝麻",
      "quantity": 2,
      "unit": "g"
    },
    {
      "name": "料理酒",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "清酒",
      "quantity": 8,
      "unit": "ml"
    },
    {
      "name": "梅子醬",
      "quantity": 15,
      "unit": "g"
    },
    {
      "name": "薑酒",
      "quantity": 30,
      "unit": "ml"
    }
  ],
  "steps": [
    "將辣椒粉、胡椒粉、蒜末、韓式辣醬、醬油、砂糖、15ml 料理酒、清酒、梅子醬、薑酒混合調製成醬料。",
    "將豬前腿肉與調製好的醬料拌勻，密封後放入冰箱冷藏醃製至少 30 分鐘以上。",
    "依據食用份量取出醃製好的豬肉，並將大蔥切段、洋蔥切絲、青陽辣椒切片備用。",
    "以中火熱鍋，不需另外加油，直接放入醃好的豬肉拌炒。",
    "肉炒至約半熟狀態時，加入洋蔥絲繼續翻炒，直到洋蔥呈微透明狀且豬肉完全熟透。",
    "放入切好的大蔥與青陽辣椒，快速翻炒約 30 秒後關火。",
    "關火後淋上香油拌勻，並撒上白芝麻即可上桌。"
  ],
  "notes": [
    "重量估算：1 顆洋蔥約 200 g，1 支大蔥約 100 g，2 支辣椒約 20 g。",
    "份量換算：本食譜將 1T 換算為 15 g/ml，2T 為 30 g/ml。少許胡椒估算為 1 g，白芝麻為 2 g。",
    "烹飪小撇步：因醃肉已有油脂且含糖，不需額外加油即可炒出香氣，但需注意火力避免燒焦。",
    "保存建議：醃好的豬肉在冷藏下可保存 3-5 天，隨吃隨炒風味最佳。"
  ]
}