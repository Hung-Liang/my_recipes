{
  "name": "高蛋白酥脆牛肉艾瑞斯餅",
  "description": "一份高蛋白、美味的酥脆牛肉艾瑞斯餅食譜，搭配清爽的白蒜醬。",
  "servings": {
    "quantity": 5,
    "unit": "份"
  },
  "tags": [
    "中東",
    "家常菜",
    "牛肉",
    "高蛋白",
    "點心/小吃"
  ],
  "ingredients": [
    {
      "name": "低脂牛絞肉（5%或以下）",
      "quantity": 800,
      "unit": "g"
    },
    {
      "name": "中型洋蔥",
      "quantity": 200,
      "unit": "g"
    },
    {
      "name": "大蒜",
      "quantity": 20,
      "unit": "g"
    },
    {
      "name": "新鮮香菜",
      "quantity": 30,
      "unit": "g"
    },
    {
      "name": "煙燻紅椒粉",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "黑胡椒粉",
      "quantity": 2.5,
      "unit": "g"
    },
    {
      "name": "卡宴辣椒粉",
      "quantity": 2.5,
      "unit": "g"
    },
    {
      "name": "鹽 (內餡用)",
      "quantity": 12,
      "unit": "g"
    },
    {
      "name": "全麥皮塔餅",
      "quantity": 315,
      "unit": "g"
    },
    {
      "name": "烹飪噴油（酪梨油）",
      "quantity": 5,
      "unit": "ml"
    },
    {
      "name": "0% 脂肪希臘優格",
      "quantity": 120,
      "unit": "g"
    },
    {
      "name": "低脂美乃滋",
      "quantity": 60,
      "unit": "g"
    },
    {
      "name": "檸檬汁",
      "quantity": 20,
      "unit": "ml"
    },
    {
      "name": "蜂蜜",
      "quantity": 7,
      "unit": "g"
    },
    {
      "name": "蒜粉",
      "quantity": 3,
      "unit": "g"
    },
    {
      "name": "鹽 (白蒜醬用)",
      "quantity": 1.5,
      "unit": "g"
    }
  ],
  "steps": [
    "將牛絞肉、切細丁的洋蔥、切末的大蒜、切碎的新鮮香菜、煙燻紅椒粉、黑胡椒粉、卡宴辣椒粉與鹽混合均勻，作為阿拉耶斯內餡。",
    "將皮塔餅切開，填入調製好的牛肉餡並壓平。",
    "平底鍋噴少許油，放入皮塔餅，每面煎 2-3 分鐘，直至外皮酥脆且肉餡熟透。若想增加烤痕，可使用烤紋平底鍋。",
    "調製白蒜醬：將希臘優格、低脂美乃滋、半顆檸檬汁、蜂蜜、蒜粉及鹽混合均勻即可。"
  ],
  "notes": [
    "可選配料（內餡）：2 根切碎的青辣椒（約 30 g），喜歡辣味者可加入。",
    "蜂蜜與蒜粉的用量可根據個人口味調整為 1-2 茶匙。",
    "建議當天趁熱享用以維持最佳酥脆口感。",
    "保存建議：完全冷卻後用錫箔紙包好，可冷藏保存 5 天。",
    "回溫方式：拆開錫箔紙，微波 2-3 分鐘移除冷氣，再使用平底鍋或氣炸鍋加熱至外皮恢復酥脆。",
    "中型洋蔥：1 顆約為 200 g。",
    "大蒜：4 瓣約為 20 g。",
    "全麥皮塔餅：5 片（每片 63 g）換算為 315 g。",
    "檸檬汁：0.5 顆約換算為 20 ml。",
    "鹽 (內餡)：2 tsp 約換算為 12 g。",
    "煙燻紅椒粉、卡宴辣椒粉、黑胡椒粉：1-2 tsp 約換算為 2.5-5 g。",
    "蜂蜜：1 tsp 約換算為 7 g。",
    "蒜粉：1 tsp 約換算為 3 g。",
    "鹽 (白蒜醬)：0.25 tsp 約換算為 1.5 g。"
  ]
}