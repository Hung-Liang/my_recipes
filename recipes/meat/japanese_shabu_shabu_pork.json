{
  "name": "日式蔥香涼拌涮豬肉",
  "description": "這是一道能在 10 分鐘內快速完成的涼拌料理，利用涮豬肉片搭配濃郁的蔥香與微辣醬汁，清爽又開胃。",
  "servings": {
    "quantity": 2,
    "unit": "人份"
  },
  "tags": [
    "豬肉",
    "日式",
    "高蛋白",
    "懶人料理"
  ],
  "ingredients": [
    {
      "name": "豬肉片 (涮涮鍋用)",
      "quantity": 300,
      "unit": "g"
    },
    {
      "name": "米酒",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "鹽",
      "quantity": 1,
      "unit": "g"
    },
    {
      "name": "大蔥",
      "quantity": 100,
      "unit": "g"
    },
    {
      "name": "芝麻油",
      "quantity": 22.5,
      "unit": "ml"
    },
    {
      "name": "砂糖",
      "quantity": 22.5,
      "unit": "g"
    },
    {
      "name": "白醋",
      "quantity": 22.5,
      "unit": "ml"
    },
    {
      "name": "醬油",
      "quantity": 22.5,
      "unit": "ml"
    },
    {
      "name": "韓式辣醬",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "大蒜粉",
      "quantity": 2.5,
      "unit": "g"
    },
    {
      "name": "白芝麻",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "黑胡椒",
      "quantity": 1,
      "unit": "g"
    }
  ],
  "steps": [
    "在鍋中將水煮沸，加入米酒與鹽。",
    "放入豬肉片與切段的大蔥煮至熟透。",
    "將煮熟的肉片與蔥段撈起，充分瀝乾水分。",
    "將芝麻油、砂糖、白醋、醬油、韓式辣醬、大蒜粉、白芝麻與黑胡椒混合均勻製成醬汁。",
    "將瀝乾的食材與醬汁充分拌勻即可完成。"
  ],
  "notes": [
    "大蔥：1 根（標準大小）估計約為 100 g。",
    "單位換算說明：本食譜已將大匙（15 ml/g）與小匙（5 ml/g）標準化為計量單位。",
    "調味估算：鹽一小撮估計為 1 g；份量較多的芝麻與黑胡椒分別以 5 g 與 1 g 計入。",
    "本食譜已將日式醬油依台灣常用醬油比例進行標準化標示。"
  ]
}