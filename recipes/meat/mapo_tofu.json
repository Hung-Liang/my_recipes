{
  "name": "麻婆豆腐",
  "description": "香到靠北一口肉配三口飯麻婆豆腐",
  "servings": {
    "quantity": 4,
    "unit": "份"
  },
  "tags": [
    "中式",
    "懶人料理",
    "豆腐",
    "豬肉/牛肉"
  ],
  "ingredients": [
    {
      "name": "豬絞肉",
      "quantity": 600,
      "unit": "g"
    },
    {
      "name": "板豆腐",
      "quantity": 800,
      "unit": "g"
    },
    {
      "name": "薑",
      "quantity": 50,
      "unit": "g"
    },
    {
      "name": "蒜",
      "quantity": 50,
      "unit": "g"
    },
    {
      "name": "蔥花",
      "quantity": 10,
      "unit": "g"
    },
    {
      "name": "豆瓣醬",
      "quantity": 45,
      "unit": "g"
    },
    {
      "name": "醬油",
      "quantity": 45,
      "unit": "ml"
    },
    {
      "name": "米酒",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "白胡椒",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "味精",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "水",
      "quantity": 300,
      "unit": "ml"
    }
  ],
  "steps": [
    "將絞肉炒碎。",
    "加入蒜末、薑末一起煸香。",
    "加入白胡椒拌炒均勻。",
    "加入板豆腐、豆瓣醬、醬油、米酒、水。",
    "使用萬用鍋或壓力鍋之「豬雞鴨」行程加壓 12 分鐘。",
    "起鍋加入味精拌勻並撒上蔥花。"
  ],
  "notes": [
    "煸香的步驟可以省略，但成品會少一股焦香味。",
    "板豆腐：1 盒約為 400 g，2 盒換算為 800 g。",
    "薑、蒜：10 片/顆約換算為 50 g。",
    "豆瓣醬、醬油：3 匙（大匙）約換算為 45 g/ml。",
    "米酒：2 匙約換算為 30 ml。",
    "白胡椒、味精：1 匙（小匙）約換算為 5 g。"
  ]
}
