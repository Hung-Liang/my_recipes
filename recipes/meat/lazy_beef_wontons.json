{
  "name": "懶人牛肉餛飩",
  "description": "這是一道免包、免煮水的創新版餛飩料理。透過將食材層層堆疊並蒸煮，能快速鎖住牛肉與青菜的鮮甜，適合追求效率且注重營養的忙碌族群。",
  "servings": {
    "quantity": 2,
    "unit": "份"
  },
  "tags": [
    "中式",
    "低碳",
    "懶人料理",
    "牛肉",
    "豬肉",
    "電鍋"
  ],
  "ingredients": [
    {
      "name": "牛絞肉",
      "quantity": 350,
      "unit": "g"
    },
    {
      "name": "大蒜",
      "quantity": 20,
      "unit": "g"
    },
    {
      "name": "薑",
      "quantity": 10,
      "unit": "g"
    },
    {
      "name": "白胡椒",
      "quantity": 1,
      "unit": "g"
    },
    {
      "name": "蠔油",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "醬油",
      "quantity": 45,
      "unit": "ml"
    },
    {
      "name": "芝麻香油",
      "quantity": 5,
      "unit": "ml"
    },
    {
      "name": "赤藻糖",
      "quantity": 10,
      "unit": "g"
    },
    {
      "name": "青菜",
      "quantity": 200,
      "unit": "g"
    },
    {
      "name": "餛飩皮",
      "quantity": 60,
      "unit": "g"
    }
  ],
  "steps": [
    "調製餡料：將牛絞肉加入蒜末、薑末、白胡椒、蠔油、醬油、芝麻香油與赤藻糖，充分攪拌均勻至入味。",
    "底部鋪平：準備一個平底深盤，在盤底均勻鋪上一層喜歡的青菜作為基底。",
    "鋪上肉餡：將調味好的牛絞肉平整地鋪在青菜層上方。",
    "覆盖皮層：將餛飩皮表面輕輕沾水，均勻地鋪蓋在最上層。",
    "蒸煮熟化：放入電鍋（外鍋約 1 杯水）或蒸鍋中，蒸煮約 15 分鐘直到牛肉完全熟透。",
    "最後調味：取出後，依據個人喜好淋上醬汁或配料即可享用。"
  ],
  "notes": [
    "大蒜：4 瓣約為 20 g。",
    "薑：一小塊約為 10 g。",
    "餛飩皮：12 張約為 60 g。",
    "青菜：200 g 約為兩份足夠鋪底的份量。",
    "選加配料：醋、辣椒醬、蔥花為選加項目，可依個人口味於完成後加入。",
    "營養素參考（每份）：熱量約 465 kcal、蛋白質 34.5 g、碳水 28 g、脂肪 22.5 g。"
  ]
}
