{
  "filename": "spicy_cold_dressing.json",
  "name": "涼拌汁",
  "description": "萬能通用涼拌醬汁，鮮香微辣且層次豐富，適合各式涼菜與麵食拌勻即食。",
  "servings": {
    "quantity": 1,
    "unit": "份"
  },
  "tags": [
    "澱粉",
    "醬汁"
  ],
  "ingredients": [
    {
      "name": "蒜末",
      "quantity": 15,
      "unit": "g"
    },
    {
      "name": "蔥花",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "薑末",
      "quantity": 2,
      "unit": "g"
    },
    {
      "name": "香菜",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "醬油",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "味極鮮醬油",
      "quantity": 15,
      "unit": "ml"
    },
    {
      "name": "蠔油",
      "quantity": 15,
      "unit": "ml"
    },
    {
      "name": "香醋",
      "quantity": 30,
      "unit": "ml"
    },
    {
      "name": "白糖",
      "quantity": 7.5,
      "unit": "g"
    },
    {
      "name": "香油",
      "quantity": 15,
      "unit": "ml"
    },
    {
      "name": "小米辣",
      "quantity": 5,
      "unit": "g"
    },
    {
      "name": "白芝麻",
      "quantity": 2,
      "unit": "g"
    }
  ],
  "steps": [
    "將蒜末、蔥花、薑末、香菜、小米辣及白芝麻放入容器底部。",
    "倒入醬油、味極鮮醬油、蠔油與香醋。",
    "加入白糖及香油，充分攪拌直到糖分完全溶解。",
    "將醬汁淋在準備好的食材（如皮蛋、拍黃瓜、涼皮等）上，拌勻即可享用。"
  ],
  "notes": [
    "單位換算：1 大勺 (tbsp) 約為 15 ml，1 小勺 (tsp) 或「適量」在比例中已換算為估計克數。",
    "數值估算說明：蒜末、蔥花、香菜等辛香料已根據標準烹飪比例設定克數；小米辣可依個人口味增減。",
    "此醬汁比例適用於：涼拌三絲、涼拌皮蛋、宮保肉丁/蝦球、涼拌白肉、涼拌金針菇、涼拌黃瓜及涼拌秋葵。",
    "本食譜已將生抽/老抽轉換為台灣常用醬油比例調整"
  ]
}
